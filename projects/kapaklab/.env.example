# Required for real AI generation. Create at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Current defaults. Override only when you deliberately want another model.
OPENAI_TEXT_MODEL=gpt-5.6
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium

# true = local no-cost previews when there is no API key (for UI/testing only)
DEMO_MODE=true
